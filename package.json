{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Personal portfolio site for Mariano Zunino, built with Hugo.",
  "homepage": "https://mzunino.com.uy/",
  "repository": {
    "type": "git",
    "url": "https://github.com/marianozunino/marianozunino.github.io"
  },
  "author": "Mariano Zunino",
