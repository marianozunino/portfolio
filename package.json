  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "8.0.0",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "postcss-cli": "11.0.1",
    "prettier": "3.8.4",
    "prettier-plugin-go-template": "0.0.15"
  },
  "hugo-bin": {
    "buildTags": "extended"
  },
  "packageManager": "npm@11.1.0+sha1.dba08f7d0f5301ebedaf968b4f74b2282f97a750"
}
